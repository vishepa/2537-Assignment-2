<li class="px-6 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center font-semibold uppercase">
            <%= user.username.charAt(0) %>
        </div>
        <div>
            <p class="font-medium text-slate-900"><%= user.username %></p>
            <% if (user.user_type === 'admin') { %>
                <span class="inline-block mt-0.5 px-2 py-0.5 text-xs font-medium rounded-full bg-indigo-100 text-indigo-700">Admin</span>
            <% } else { %>
                <span class="inline-block mt-0.5 px-2 py-0.5 text-xs font-medium rounded-full bg-slate-100 text-slate-600">User</span>
            <% } %>
        </div>
    </div>
    <div class="flex gap-2">
        <form action="/admin/promote" method="post" class="inline">
            <input type="hidden" name="username" value="<%= user.username %>">
            <button type="submit" class="px-3 py-1.5 text-sm font-medium bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg shadow-sm transition">
                Promote
            </button>
        </form>
        <form action="/admin/demote" method="post" class="inline">
            <input type="hidden" name="username" value="<%= user.username %>">
            <button type="submit" class="px-3 py-1.5 text-sm font-medium bg-white hover:bg-slate-100 text-slate-700 border border-slate-300 rounded-lg shadow-sm transition">
                Demote
            </button>
        </form>
    </div>
</li>
