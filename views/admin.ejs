<%- include("templates/header") %>

<section>
    <div class="mb-6">
        <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">Admin Dashboard</h1>
        <p class="text-slate-600 mt-1">Manage user roles and permissions.</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-200 bg-slate-50">
            <h2 class="font-semibold text-slate-900">All Users (<%= users.length %>)</h2>
        </div>
        <ul class="divide-y divide-slate-200">
            <% for (let i = 0; i < users.length; i++) { %>
                <%- include("templates/user", { user: users[i] }) %>
            <% } %>
        </ul>
    </div>
</section>

<%- include("templates/footer") %>
