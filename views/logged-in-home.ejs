<%- include("templates/header") %>

<section class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 sm:p-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-2">
            Hello, <%= username %>!
        </h1>
        <p class="text-slate-600 mb-6">
            Scope the members area
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
            <a href="/members" class="w-full sm:w-auto inline-flex items-center justify-center px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg shadow-sm transition">
                Go to Members Area
            </a>
            <a href="/logout" class="w-full sm:w-auto inline-flex items-center justify-center px-5 py-2.5 bg-white hover:bg-slate-100 text-slate-700 font-semibold rounded-lg border border-slate-300 shadow-sm transition">
