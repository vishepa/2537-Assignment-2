<%- include("templates/header") %>

<section>
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8 gap-4">
        <div>
            <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">Members Area</h1>
            <p class="text-slate-600 mt-1">Hello, <span class="font-semibold text-slate-800"><%= username %></span>! Enjoy your stay.</p>
        </div>
        <a href="/logout" class="inline-flex items-center justify-center px-4 py-2 bg-white hover:bg-slate-100 text-slate-700 font-semibold rounded-lg border border-slate-300 shadow-sm transition w-full sm:w-auto">
            Log Out
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6">
        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-md transition">
            <img src="/ben.png" alt="Ben" class="w-full h-64 object-cover">
            <div class="p-4">
                <h3 class="font-semibold text-slate-900">Ben</h3>
            </div>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-md transition">
            <img src="/bingzoid.png" alt="Bingzoid" class="w-full h-64 object-cover">
            <div class="p-4">
                <h3 class="font-semibold text-slate-900">Bingzoid</h3>
            </div>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-md transition">
            <img src="/glup.png" alt="Glup" class="w-full h-64 object-cover">
            <div class="p-4">
                <h3 class="font-semibold text-slate-900">Glup</h3>
            </div>
        </div>
    </div>
</section>

<%- include("templates/footer") %>
